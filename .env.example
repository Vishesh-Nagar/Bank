# ─── Database ────────────────────────────────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=CHANGE_ME_strong_password_here

# Per-service DB hosts — each service connects to its own dedicated MySQL instance.
# These are injected explicitly per service in docker-compose; no need to change them
# unless you are deploying databases to external hosts.
DB_HOST_USERS=bank-mysql-users
DB_HOST_ACCOUNTS=bank-mysql-accounts
DB_HOST_PAYMENTS=bank-mysql-payments

# ─── Secrets ─────────────────────────────────────────────────────────────────
# Generate with PowerShell: -join ((1..64) | % { '{0:x}' -f (Get-Random -Max 16) })
# or: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_string
INTERNAL_SERVICE_SECRET=CHANGE_ME_generate_another_64_char_hex_string

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=bank-kafka:29092

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=bank-redis
REDIS_PORT=6379

# ─── CORS ────────────────────────────────────────────────────────────────────
# In production, change this to your actual domain only:
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────────────────────
# Override to change where service logs are written (default: ./logs/)
# LOG_PATH=/var/log/bank

# ─── Service URLs ────────────────────────────────────────────────────────────
# Override these if you are deploying services to separate domains
USER_SERVICE_URL=http://bank-user-service:8081
ACCOUNT_SERVICE_URL=http://bank-account-service:8082
PAYMENT_SERVICE_URL=http://bank-payment-service:8083
NOTIFICATION_SERVICE_URL=http://bank-notification-service:8084
API_GATEWAY_URL=http://bank-api-gateway:8080

# ─── Tracing ─────────────────────────────────────────────────────────────────
ZIPKIN_HOST=bank-zipkin
